# GOOGLE SERVICE ACCOUNT CREDENTIALS
# 1. Download the JSON key from Google Cloud Console
# 2. Copy 'client_email' to VITE_SA_CLIENT_EMAIL
# 3. Copy the entire 'private_key' string to VITE_SA_PRIVATE_KEY (including the BEGIN/END lines)

VITE_SA_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
VITE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_LONG_KEY_HERE\n-----END PRIVATE KEY-----\n"
